<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white">

    <ScrollView
        android:id="@+id/home_sv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.05" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.95" />

            <!-- 날씨 -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/home_weather_vp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </androidx.viewpager2.widget.ViewPager2>

            <!-- 디데이 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/home_dday_rv"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:clipToPadding="false"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:translationY="-50dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/home_weather_vp" />
<!--            <HorizontalScrollView-->
<!--                android:id="@+id/home_dday_cl"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="100dp"-->
<!--                android:translationY="-50dp"-->
<!--                android:paddingStart="15dp"-->
<!--                android:paddingEnd="15dp"-->
<!--                android:orientation="horizontal"-->
<!--                android:clipToPadding="false"-->
<!--                android:scrollbars="none"-->
<!--                app:layout_constraintHorizontal_bias="0.263"-->
<!--                app:layout_constraintEnd_toEndOf="parent"-->
<!--                app:layout_constraintStart_toStartOf="parent"-->
<!--                app:layout_constraintTop_toBottomOf="@+id/home_weather_vp">-->
<!--                <androidx.recyclerview.widget.RecyclerView-->
<!--                    android:id="@+id/home_dday_rv"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="match_parent"-->
<!--                    android:clipToPadding="false"-->
<!--                    android:paddingLeft="15dp"-->
<!--                    android:paddingRight="5dp"-->
<!--                    app:layout_constraintBottom_toBottomOf="parent"-->
<!--                    app:layout_constraintEnd_toEndOf="parent"-->
<!--                    app:layout_constraintStart_toStartOf="parent"-->
<!--                    app:layout_constraintTop_toTopOf="parent">-->

<!--                </androidx.recyclerview.widget.RecyclerView>-->
<!--            </HorizontalScrollView>-->


            <!-- 우리 동네 핫플레이스 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/home_hot_place_cl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:translationY="-50dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/home_dday_rv">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.05" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.95" />

                <TextView
                    android:id="@+id/textView27"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="35dp"
                    android:fontFamily="@font/pretendard_bold"
                    android:text="우리 동네 HOT Place"
                    android:textColor="@color/black"
                    android:textSize="23sp"
                    app:layout_constraintStart_toStartOf="@id/guideline3"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/home_hot_place_rv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingLeft="15dp"
                    android:paddingRight="5dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/textView27" />

                <ImageView
                    android:id="@+id/imageView22"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    app:layout_constraintBottom_toBottomOf="@+id/textView27"
                    app:layout_constraintStart_toEndOf="@+id/textView27"
                    app:layout_constraintTop_toTopOf="@+id/textView27"
                    app:srcCompat="@drawable/img_home_hot_place" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 광고 배너 -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/home_ad_vp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp"
                android:scaleType="centerCrop"
                android:translationY="-50dp"
                app:layout_constraintEnd_toEndOf="@id/guideline_end"
                app:layout_constraintStart_toStartOf="@id/guideline_start"
                app:layout_constraintTop_toBottomOf="@+id/home_hot_place_cl" />

            <!-- 우리 동네 인기 게시물 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/home_hot_post_cl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:translationY="-50dp"
                app:layout_constraintEnd_toEndOf="@id/guideline_end"
                app:layout_constraintStart_toStartOf="@id/guideline_start"
                app:layout_constraintTop_toBottomOf="@+id/home_ad_vp">

                <TextView
                    android:id="@+id/textView35"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="35dp"
                    android:fontFamily="@font/pretendard_bold"
                    android:text="우리 동네 인기 게시물"
                    android:textColor="@color/black"
                    android:textSize="23sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/home_hot_post_rv"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginTop="5dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/textView35" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 도전! 반려동물 OX 퀴즈 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/home_ox_quiz_cl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:translationY="-50dp"
                app:layout_constraintEnd_toEndOf="@id/guideline_end"
                app:layout_constraintStart_toStartOf="@id/guideline_start"
                app:layout_constraintTop_toBottomOf="@+id/home_hot_post_cl"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tv_quiz_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="35dp"
                    android:fontFamily="@font/pretendard_bold"
                    android:text="도전! 반려동물 OX 퀴즈"
                    android:textColor="@color/black"
                    android:textSize="23sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Quiz Box -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/quiz_box"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="140dp"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/bg_quiz_box"
                    app:layout_constraintTop_toBottomOf="@id/tv_quiz_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:id="@+id/iv_quiz_dog"
                        android:layout_width="70dp"
                        android:layout_height="90dp"
                        android:layout_marginStart="10dp"
                        android:src="@drawable/img_quiz_dog"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageView
                        android:id="@+id/iv_quiz_cat"
                        android:layout_width="70dp"
                        android:layout_height="90dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/img_quiz_cat"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_quiz_question"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginTop="30dp"
                        android:layout_marginBottom="30dp"
                        android:fontFamily="@font/pretendard_bold"
                        android:gravity="center"
                        android:text="퀴즈를 불러오는 중입니다..."
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iv_quiz_dog"
                        app:layout_constraintEnd_toStartOf="@id/iv_quiz_cat" />

                    <!-- Overlay (Visible upon submit) -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/quiz_overlay"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:background="@drawable/bg_quiz_overlay"
                        android:visibility="gone"
                        android:padding="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/tv_quiz_result"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="정답입니다"
                            android:textColor="@color/main_color1"
                            android:textSize="20sp"
                            android:fontFamily="@font/pretendard_bold"
                            android:textStyle="bold"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toTopOf="@id/tv_quiz_explanation"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/tv_quiz_explanation"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:text=""
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:lineSpacingExtra="3dp"
                            app:layout_constraintTop_toBottomOf="@id/tv_quiz_result"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>

                        <ImageView
                            android:id="@+id/iv_quiz_next"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:padding="5dp"
                            android:src="@drawable/img_arrow_right"
                            android:background="@drawable/bg_circle_gray"
                            app:tint="@color/white"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />


                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- O / X Buttons -->
                <LinearLayout
                    android:id="@+id/ll_quiz_buttons"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:orientation="horizontal"
                    android:weightSum="1"
                    app:layout_constraintTop_toBottomOf="@id/quiz_box"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <FrameLayout
                        android:id="@+id/fl_btn_o"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="0.48"
                        android:background="@drawable/bg_quiz_o">

                        <TextView
                            android:id="@+id/tv_btn_o"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="O"
                            android:textColor="@color/blue"
                            android:textSize="50sp"
                            android:fontFamily="@font/pretendard_bold"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.04" />

                    <FrameLayout
                        android:id="@+id/fl_btn_x"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="0.48"
                        android:background="@drawable/bg_quiz_x">

                        <TextView
                            android:id="@+id/tv_btn_x"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="X"
                            android:textColor="@color/orange"
                            android:textSize="50sp"
                            android:fontFamily="@font/pretendard_bold"
                            android:textStyle="bold" />
                    </FrameLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_quiz_helper_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:text="정답이면 O 틀리면 X를 눌러주세요!"
                    android:fontFamily="@font/pretendard_medium"
                    android:textColor="@color/gray5"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/ll_quiz_buttons"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>